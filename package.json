{
  "name": "petjournal.api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig-build.json",
    "dev": "sucrase-node src/main/server.ts",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "lint": "eslint .",
    "lint:fix": "yarn run lint --fix",
    "migrate": "prisma migrate dev",
    "test": "jest --passWithNoTests --no-cache --runInBand --silent --noStackTrace",
    "prepare": "husky install",
    "seed": "prisma db seed",
    "start": "node dist/main/server.js",
    "test:watch": "yarn test --watch",
    "test:verbose": "jest --passWithNoTests --no-cache --runInBand",
    "test:staged": "yarn test --findRelatedTests",
    "test:coverage": "yarn test:verbose --coverage",
    "test:unit": "yarn test -c jest-unit-config.js",
    "test:integration": "yarn test -c jest-integration-config.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^17.4.4",
    "@commitlint/config-conventional": "^17.4.4",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/luxon": "^3.6.2",
    "@types/mime-types": "^3.0.1",
    "@types/module-alias": "^2.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^18.15.5",
    "@types/supertest": "^2.0.12",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/uuid": "^9.0.1",
    "@types/validator": "^13.7.14",
    "@typescript-eslint/eslint-plugin": "^5.43.0",
    "eslint": "^8.0.1",
    "eslint-config-standard-with-typescript": "^34.0.1",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "husky": "^8.0.0",
    "jest": "^29.5.0",
    "lint-staged": "^13.2.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.7.0",
    "sucrase": "^3.32.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.2"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-prom-bundle": "^8.0.0",
    "firebase": "^11.4.0",
    "firebase-admin": "^13.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "luxon": "^3.6.1",
    "mime-types": "^3.0.2",
    "module-alias": "^2.2.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^10.3.0",
    "prom-client": "^15.1.3",
    "rimraf": "^4.4.0",
    "swagger-ui-express": "^4.6.2",
    "uuid": "^9.0.0",
    "validator": "^13.9.0"
  },
  "packageManager": "yarn@3.5.0",
  "prisma": {
    "schema": "./src/infra/repos/postgresql/prisma/schema.prisma",
    "seed": "sucrase-node ./src/infra/repos/postgresql/prisma/seed.ts"
  }
